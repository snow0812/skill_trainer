# 复制为 backend/.env 后填写。启动时自动加载（见 app/config.py）。

# —— 优先：OpenAI 官方环境变量（与 SDK 一致）——
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# —— 备用：仅当未设置上方 OpenAI_* 时使用 ——
# USER_TWIN_LLM_API_KEY=
# USER_TWIN_LLM_BASE_URL=https://api.openai.com/v1
# USER_TWIN_LLM_MODEL=gpt-4o-mini

# —— 本地 Ollama 等 ——
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL=qwen2.5
